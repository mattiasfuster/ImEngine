{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2
  },
  "configurePresets": [
    {
      "name": "win64_clangcl_nmc",
      "displayName": "Windows | x64 | Clang CL | Ninja Multi-Config",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;RelWithDebInfo;Release",
        "CMAKE_C_COMPILER": "C:/Program Files/LLVM/bin/clang-cl.exe",
        "CMAKE_CXX_COMPILER": "C:/Program Files/LLVM/bin/clang-cl.exe",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_MESSAGE_LOG_LEVEL": "VERBOSE",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "toolset": {
        "value": "ClangCL",
        "strategy": "external"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev_debug",
      "configurePreset": "win64_clangcl_nmc",
      "configuration": "Debug"
    }
  ]
}
